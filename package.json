{
  "name": "media-office",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=@media-office/admin",
    "dev:mobile": "npm run start --workspace=@media-office/mobile",
    "build:admin": "npm run build --workspace=@media-office/admin",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
